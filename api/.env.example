APP_NAME="Book Store API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=book_store
# Set to true only if MongoDB is a replica set (required for transactions)
MONGODB_TRANSACTIONS=false

# JWT
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=0

# CORS (comma-separated origins, * for all)
CORS_ALLOWED_ORIGINS=*

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Cache & Session (use array/database for API)
CACHE_STORE=file
CACHE_CATALOG_ENABLED=true
CACHE_CATEGORIES_TTL=3600
CACHE_AUTHORS_TTL=3600
CACHE_BOOKS_TTL=300
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=sync

# Broadcast (disabled for API)
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=local

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
